<div class="shell auth-shell narrow-shell">
  <div class="auth-grid single-grid">
    <div class="auth-card glass">
      <h2>Reset password</h2>
      <p class="subtext">Yangi password kiriting. Saqlangandan keyin eski password ishlamaydi.</p>

      {{#if error}}<p class="message error">{{error}}</p>{{/if}}

      <form action="/api/reset-password" method="post">
        <input type="hidden" name="token" value="{{token}}" />
        <input type="hidden" name="id" value="{{id}}" />

        <label for="password">New password</label>
        <input type="password" id="password" name="password" placeholder="New strong password" required />

        <button type="submit">Save new password</button>
      </form>

      <div class="links-row single">
        <span><a href="/login">Back to login</a></span>
      </div>
    </div>
  </div>
</div>
